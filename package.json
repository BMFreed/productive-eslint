{
  "name": "productive-eslint",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6",
  "description": "Mildly strict and sufficiently practical ESLint config based on Evgeny Orekhov's eslint-config-hardcore",
  "author": "Bogdan Binitskiy",
  "contributors": [
    {
      "name": "Roman Nikitin",
      "url": "https://github.com/Stelsovich1"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BMFreed/productive-eslint.git"
  },
  "keywords": [
    "eslint",
    "config",
    "eslintconfig",
    "eslint-config",
    "practical",
    "productive"
  ],
  "main": "./dist/index.config.js",
  "types": "./dist/index.config.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.config.js",
      "types": "./dist/index.config.d.ts"
    },
    "./FIXES.md": "./FIXES.md"
  },
  "files": [
    "dist",
    "FIXES.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "tsc && eslint --fix",
    "inspect": "npx @eslint/config-inspector@latest",
    "build": "tsdown --clean --dts",
    "release": "pnpm build && pnpm publish",
    "rules:dump": "jiti scripts/dump-eslint-rules.ts",
    "rules:compare": "jiti scripts/compare-eslint-rules.ts"
  },
  "peerDependencies": {
    "eslint": "^10.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.8.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@eslint/css": "^0.14.1",
    "@eslint/markdown": "^7.5.1",
    "@smarttools/eslint-plugin-rxjs": "^1.0.22",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint-config-flat-gitignore": "^2.0.0",
    "eslint-flat-config-utils": "^3.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-jsonc": "^3.1.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-toml": "^1.3.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-yml": "^3.3.0",
    "globals": "^16.2.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^1.1.2",
    "toml-eslint-parser": "^0.10.0",
    "vue-eslint-parser": "^10.1.3",
    "yaml-eslint-parser": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/utils": "^8.56.0",
    "eslint": "^10.0.1",
    "jiti": "^2.6.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  }
}
