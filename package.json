{
  "name": "productive-eslint",
  "type": "module",
  "version": "4.1.0",
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6",
  "description": "Mildly strict and sufficiently practical ESLint config based on Evgeny Orekhov's eslint-config-hardcore",
  "author": "Bogdan Binitskiy",
  "contributors": [
    {
      "name": "Roman Nikitin",
      "url": "https://github.com/Stelsovich1"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BMFreed/productive-eslint.git"
  },
  "keywords": [
    "eslint",
    "config",
    "eslintconfig",
    "eslint-config",
    "practical",
    "productive"
  ],
  "main": "./dist/index.config.js",
  "types": "./dist/index.config.d.ts",
  "bin": {
    "productive-eslint": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.config.js",
      "types": "./dist/index.config.d.ts"
    },
    "./AGENTS.md": "./AGENTS.md"
  },
  "files": [
    "dist",
    "docs",
    "AGENTS.md"
  ],
  "pnpm": {
    "overrides": {
      "brace-expansion@^1.1.7": "1.1.13",
      "brace-expansion@^5.0.0": "5.0.6",
      "flatted@^3.2.9": "3.4.2",
      "minimatch@^3.1.2": "3.1.5",
      "minimatch@^10.2.2": "10.2.5",
      "picomatch@^2.3.1": "2.3.2",
      "picomatch@^4.0.3": "4.0.4",
      "yaml@^2.0.0": "2.9.0"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "tsc && eslint --fix",
    "inspect": "npx @eslint/config-inspector@latest",
    "build": "tsdown --clean --dts",
    "test": "pnpm build && node --import jiti/register --test test/cli/*.test.ts",
    "release": "pnpm build && pnpm publish",
    "rules:dump": "jiti scripts/dump-eslint-rules.ts",
    "rules:compare": "jiti scripts/compare-eslint-rules.ts"
  },
  "peerDependencies": {
    "eslint": "^10.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.8.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/css": "^1.2.0",
    "@smarttools/eslint-plugin-rxjs": "^1.0.22",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-toml": "^1.3.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-yml": "^3.3.2",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "local-pkg": "^1.1.2",
    "toml-eslint-parser": "^1.0.3",
    "vue-eslint-parser": "^10.1.3",
    "yaml-eslint-parser": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@typescript-eslint/utils": "^8.59.3",
    "eslint": "^10.4.0",
    "rxjs": "7.8.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3"
  }
}
